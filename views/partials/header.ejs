<style>
.layout{
    display:flex;
    min-height:100vh;
}

.sidebar{
    width:220px;
    background:#020617;
    padding:25px 15px;
    box-shadow:4px 0 20px rgba(0,0,0,.5);
}

.sidebar h1{
    color:#38bdf8;
    text-align:center;
    margin-bottom:30px;
}

.sidebar a{
    display:block;
    padding:12px;
    margin:8px 0;
    color:#cbd5f5;
    text-decoration:none;
    border-radius:8px;
}

.sidebar a:hover{
    background:#1e293b;
}

.sidebar .section-title{
    margin-top:20px;
    font-size:13px;
    color:#64748b;
    padding-left:10px;
}

.topbar{
    position:fixed;
    top:0;
    right:0;
    left:220px;
    height:60px;
    background:#020617;
    display:flex;
    justify-content:flex-end;
    align-items:center;
    padding:0 25px;
    box-shadow:0 3px 20px rgba(0,0,0,.6);
}

.topbar a{
    margin-left:15px;
    padding:8px 14px;
    border-radius:8px;
    text-decoration:none;
    font-weight:bold;
}

.login-btn{background:#06b6d4;color:black;}
.register-btn{background:#22c55e;color:black;}
.profile-btn{background:#38bdf8;color:black;}
.logout-btn{background:#fb7185;color:black;}

.page{
    margin-left:220px;
    margin-top:60px;
    flex:1;
}
</style>

<div class="layout">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <h1>VivekHub</h1>

    <div class="section-title">URL SHORTENER</div>
    <a href="/">➕ Shorten URL</a>
    <a href="/shortlinks">📊 My Short Links</a>

    <div class="section-title">GENERAL</div>
    <a href="#section2">About</a>
    <a href="#section4">Contact</a>
  </div>

  <!-- TOP BAR -->
  <div class="topbar">
    <% if (!user) { %>
      <a class="login-btn" href="/login">Login</a>
      <a class="register-btn" href="/register">Register</a>
    <% } else { %>
      <a class="profile-btn" href="/profile">Profile</a>
      <a class="logout-btn" href="/logout">Logout</a>
    <% } %>
  </div>

  <!-- PAGE WRAPPER OPEN -->
  <div class="page">
